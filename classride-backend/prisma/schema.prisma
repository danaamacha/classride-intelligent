generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  pending
  owner
  driver
  student
  admin
}

enum OwnerStatus {
  pending
  accepted
  rejected
}

enum TripType {
  morning
  return
}

enum TripStatus {
  scheduled
  active
  completed
}

enum RequestStatus {
  pending
  accepted
  rejected
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  phoneNumber String   @id @map("phone_number")
  fullName    String   @map("full_name")
  password    String
  role        Role     @default(pending)
  fcmToken        String?  @map("fcm_token")
  refreshToken    String?  @map("refresh_token")
  createdAt       DateTime @default(now()) @map("created_at")

  owner                  Owner?
  driver                 Driver?
  student                Student?
  tripsAsDriver          Trip[]                   @relation("DriverTrips")
  notifications          Notification[]
  sentMessages           Message[]
  joinRequestsAsStudent  StudentJoinRequest[]     @relation("StudentRequests")
  joinRequestsAsOwner    StudentJoinRequest[]     @relation("OwnerRequests")
  availabilityRequests   AvailabilityRequest[]
  rideRequests           RideRequest[]
  chatParticipant1       Chat[]                   @relation("Participant1")
  chatParticipant2       Chat[]                   @relation("Participant2")

  @@map("users")
}

model Owner {
  phoneNumber String      @id @map("phone_number")
  busLogo     String?     @map("bus_logo")
  homeTown    String?     @map("home_town")
  latitude    Float?
  longitude   Float?
  status      OwnerStatus @default(pending)
  createdAt   DateTime    @default(now()) @map("created_at")

  user         User          @relation(fields: [phoneNumber], references: [phoneNumber])
  buses        Bus[]
  drivers      Driver[]
  students     Student[]
  destinations Destination[]

  @@map("owners")
}

model Driver {
  phoneNumber String  @id @map("phone_number")
  homeTown    String? @map("home_town")
  ownerPhone  String  @map("owner_phone")

  user  User  @relation(fields: [phoneNumber], references: [phoneNumber])
  owner Owner @relation(fields: [ownerPhone], references: [phoneNumber])

  @@map("drivers")
}

model Destination {
  destinationId Int     @id @default(autoincrement()) @map("destination_id")
  name          String
  location      String?
  ownerPhone    String? @map("owner_phone")

  owner    Owner?    @relation(fields: [ownerPhone], references: [phoneNumber])
  students Student[]
  trips    Trip[]

  @@map("destinations")
}

model Student {
  phoneNumber   String  @id @map("phone_number")
  destinationId Int?    @map("destination_id")
  homeAddress   String? @map("home_address")
  latitude      Float?
  longitude     Float?
  ownerPhone    String? @map("owner_phone")

  user              User                      @relation(fields: [phoneNumber], references: [phoneNumber])
  destination       Destination?              @relation(fields: [destinationId], references: [destinationId])
  owner             Owner?                    @relation(fields: [ownerPhone], references: [phoneNumber])
tripAssignments   StudentAssignment[]
  weeklySchedules   StudentWeeklySchedule[]
  scheduleOverrides StudentScheduleOverride[]
  payments          Payment[]

  @@map("students")
}

model Bus {
  busId      Int     @id @default(autoincrement()) @map("bus_id")
  busName    String? @map("bus_name")
  capacity   Int
  ownerPhone String  @map("owner_phone")

  owner Owner  @relation(fields: [ownerPhone], references: [phoneNumber])
  trips Trip[]

  @@map("buses")
}

model Trip {
  tripId        Int        @id @default(autoincrement()) @map("trip_id")
  busId         Int?       @map("bus_id")
  driverPhone   String?    @map("driver_phone")
  destinationId Int?       @map("destination_id")
  pickupTime    String?    @map("pickup_time")
  dropoffTime   String?    @map("dropoff_time")
  date          DateTime?  @db.Date
  type          TripType?
  status        TripStatus @default(scheduled)
  schedule      DateTime?
  createdAt     DateTime   @default(now()) @map("created_at")

  bus         Bus?                @relation(fields: [busId], references: [busId])
  driver      User?               @relation("DriverTrips", fields: [driverPhone], references: [phoneNumber])
  destination Destination?        @relation(fields: [destinationId], references: [destinationId])
  assignments StudentAssignment[]
  payments    Payment[]

  @@map("trips")
}

model StudentAssignment {
  id           Int    @id @default(autoincrement())
  tripId       Int    @map("trip_id")
  studentPhone String @map("student_phone")

  trip    Trip    @relation(fields: [tripId], references: [tripId])
  student Student @relation(fields: [studentPhone], references: [phoneNumber])

  @@unique([tripId, studentPhone])
  @@map("students_assignment")
}

model Payment {
  id           Int     @id @default(autoincrement())
  tripId       Int     @map("trip_id")
  studentPhone String  @map("student_phone")
  paid         Boolean @default(false)

  trip    Trip    @relation(fields: [tripId], references: [tripId])
  student Student @relation(fields: [studentPhone], references: [phoneNumber])

  @@unique([tripId, studentPhone])
  @@map("payments")
}

model StudentWeeklySchedule {
  id                Int     @id @default(autoincrement())
  studentPhone      String  @map("student_phone")
  dayOfWeek         Int     @map("day_of_week")
  morningTime       String? @map("morning_time")
  returnTime        String? @map("return_time")
  attendanceMorning Boolean @default(true) @map("attendance_morning")
  attendanceReturn  Boolean @default(true) @map("attendance_return")

  student Student @relation(fields: [studentPhone], references: [phoneNumber])

  @@unique([studentPhone, dayOfWeek])
  @@map("student_weekly_schedules")
}

model StudentScheduleOverride {
  id                  Int      @id @default(autoincrement())
  studentPhone        String   @map("student_phone")
  date                DateTime @db.Date
  overrideMorningTime String?  @map("override_morning_time")
  overrideReturnTime  String?  @map("override_return_time")
  attendanceMorning   Boolean  @default(true) @map("attendance_morning")
  attendanceReturn    Boolean  @default(true) @map("attendance_return")

  student Student @relation(fields: [studentPhone], references: [phoneNumber])

  @@unique([studentPhone, date])
  @@map("student_schedule_overrides")
}

model StudentJoinRequest {
  reqId      Int           @id @default(autoincrement()) @map("req_id")
  ownerPhone String        @map("owner_phone")
  userPhone  String        @map("user_phone")
  status     RequestStatus @default(pending)
  reqDate    DateTime      @default(now()) @map("req_date")

  owner   User @relation("OwnerRequests", fields: [ownerPhone], references: [phoneNumber])
  student User @relation("StudentRequests", fields: [userPhone], references: [phoneNumber])

  @@map("students_join_requests")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userPhone String   @map("user_phone")
  title     String?
  body      String?
  type      String?
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userPhone], references: [phoneNumber])

  @@map("notifications")
}

model Chat {
  chatId            String @id @map("chat_id")
  participant1Phone String @map("participant_1_phone")
  participant2Phone String @map("participant_2_phone")

  participant1 User      @relation("Participant1", fields: [participant1Phone], references: [phoneNumber])
  participant2 User      @relation("Participant2", fields: [participant2Phone], references: [phoneNumber])
  messages     Message[]

  @@map("chats")
}

model Message {
  id          Int      @id @default(autoincrement())
  chatId      String   @map("chat_id")
  senderPhone String   @map("sender_phone")
  messageText String?  @map("message_text")
  sentAt      DateTime @default(now()) @map("sent_at")

  chat   Chat @relation(fields: [chatId], references: [chatId])
  sender User @relation(fields: [senderPhone], references: [phoneNumber])

  @@map("messages")
}

model AvailabilityRequest {
  id          Int      @id @default(autoincrement())
  userPhone   String   @map("user_phone")
  role        String?
  location    String?
  destination String?
  postedAt    DateTime @default(now()) @map("posted_at")

  user User @relation(fields: [userPhone], references: [phoneNumber])

  @@map("availability_requests")
}

model RideRequest {
  id          Int      @id @default(autoincrement())
  userPhone   String   @map("user_phone")
  role        String?
  location    String?
  destination String?
  postedAt    DateTime @default(now()) @map("posted_at")

  user User @relation(fields: [userPhone], references: [phoneNumber])

  @@map("ride_requests")
}
